generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Destination {
  id          String             @id @default(cuid())
  name        String
  description String
  accommodationPrice Float      @default(0)
  otherPrice         Float      @default(0)
  currency           String     @default("MYR")
  photoUrl    String
  link        String?
  details     String
  tags        String             @default("")
  days        Int                @default(0)
  nights      Int                @default(0)
  order       Int                @default(0)
  createdAt   DateTime           @default(now())
  votes       Vote[]
  media       DestinationMedia[]
}

model DestinationMedia {
  id            String      @id @default(cuid())
  destinationId String
  photoUrl      String
  caption       String      @default("")
  createdAt     DateTime    @default(now())
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
}

model Participant {
  id           String    @id @default(cuid())
  username     String    @unique
  displayName  String    @default("")
  passwordHash String
  voteCount    Int       @default(1)
  createdAt    DateTime  @default(now())
  votes        Vote[]
  messages     Message[]
  dateVotes    DateVote[]
}

model Vote {
  id            String      @id @default(cuid())
  participantId String
  destinationId String
  createdAt     DateTime    @default(now())
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@unique([participantId, destinationId])
}

model Settings {
  key   String @id
  value String
}

model DateOption {
  id        String     @id @default(cuid())
  date      String
  label     String     @default("")
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  votes     DateVote[]
}

model DateVote {
  id            String      @id @default(cuid())
  participantId String
  dateOptionId  String
  createdAt     DateTime    @default(now())
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  dateOption    DateOption  @relation(fields: [dateOptionId], references: [id], onDelete: Cascade)

  @@unique([participantId, dateOptionId])
}

model Message {
  id            String      @id @default(cuid())
  participantId String
  username      String
  content       String
  destinationId String?
  createdAt     DateTime    @default(now())
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
}
